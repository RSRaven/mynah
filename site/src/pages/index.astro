---
// Mynah — animated landing page (custom route, outside the Starlight docs layout).
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/landing.css';

const base = import.meta.env.BASE_URL;
const docs = `${base}get-started/install/`;
const docsMac = `${base}get-started/install-macos/`;
const gh = 'https://github.com/RSRaven/mynah';
const releases = `${gh}/releases`;
const latestRelease = `${gh}/releases/latest`;
// Download buttons resolve the newest *versioned* asset at click time (see the inline script
// below): the GitHub API gives the latest release's assets, we match the Windows installer /
// macOS zip by name, and navigate to it — so the downloaded file keeps its version number
// (e.g. Mynah-Setup-0.4.0.exe). If the API is unreachable, the buttons fall back to the
// /releases/latest page (their href), which always lists the versioned files.
const repoApi = 'https://api.github.com/repos/RSRaven/mynah/releases/latest';
const title = 'Mynah — local push-to-talk voice typing';
const description =
  'Hold a key, talk, and the text is typed at your cursor — in any app. Local, GPU-accelerated voice typing for Windows and macOS. Free, open-source, 100% offline. No cloud, no telemetry.';
const ogImage = `${base}brand/mynah-logo.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}brand/favicon-32.png`} />
    <link rel="apple-touch-icon" href={`${base}brand/apple-touch-icon.png`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#070a12" />
  </head>
  <body>
    <!-- ===================== NAV ===================== -->
    <nav class="top">
      <div class="wrap">
        <a class="brand" href={base}>
          <img src={`${base}brand/mynah-logo.png`} alt="Mynah" width="30" height="30" />
          <span><b>My</b><span class="accent">nah</span></span>
        </a>
        <div class="links">
          <a href="#how">How it works</a>
          <a href="#features">Features</a>
          <a href="#customize">Customize</a>
          <a href="#why">Why</a>
          <a href={docs}>Docs</a>
          <a href={latestRelease} class="btn btn-primary">Download</a>
        </div>
      </div>
    </nav>

    <!-- ===================== HERO ===================== -->
    <header class="hero">
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <span class="eyebrow"><span class="dot"></span> 100% offline · no cloud · no telemetry</span>
          <h1 class="hero-title">Hold a key.<br />Talk. <span class="grad">It's typed.</span></h1>
          <p class="lede">
            <span class="tagline">Like a mynah, it listens and echoes you — perfectly.</span>{' '}
            Local, GPU-accelerated voice typing for Windows and macOS. Speak into any app and the
            text lands at your cursor. Your voice never leaves the machine.
          </p>
          <span class="dl-label">Download free <span class="dl-sep">·</span> latest release</span>
          <div class="cta-row">
            <a href={latestRelease} data-dl="windows" class="btn btn-primary btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5l8-1.1v7.2H3V5.5zM3 18.5l8 1.1v-7.1H3v6zM12 4.2L22 3v9.6h-10V4.2zM12 19.8L22 21v-8.4H12v7.2z"></path></svg>
              Windows
            </a>
            <a href={latestRelease} data-dl="macos" class="btn btn-primary btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.4 12.6c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9-.7 0-1.8-.8-3-.8-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.7 2.2 1.1 0 1.5-.7 2.8-.7 1.3 0 1.6.7 2.8.7 1.2 0 1.9-1.1 2.6-2.1.8-1.2 1.1-2.3 1.2-2.4-.1 0-2.3-.9-2.3-3.5zM14.2 5.8c.6-.8 1-1.8.9-2.8-.9 0-2 .6-2.6 1.3-.6.7-1.1 1.7-1 2.7 1 0 2-.5 2.7-1.2z"></path></svg>
              macOS
            </a>
            <a href={gh} class="btn btn-ghost btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.6 2 12.3c0 4.5 2.9 8.3 6.8 9.7.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.4-3.4-1.4-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.7.3-1.1.6-1.4-2.2-.3-4.6-1.2-4.6-5.1 0-1.1.4-2 1-2.7-.1-.3-.5-1.3.1-2.7 0 0 .8-.3 2.7 1a9 9 0 014.9 0c1.9-1.3 2.7-1 2.7-1 .6 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5.1.4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10.3 10.3 0 0022 12.3C22 6.6 17.5 2 12 2z"></path></svg>
              GitHub
            </a>
          </div>
          <p class="dl-note">Windows 10/11 · macOS (Apple Silicon) · free &amp; open source</p>
          <div class="badges">
            <span class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="var(--idle)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linejoin="round"></path></svg> On-device Whisper large-v3</span>
            <span class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="var(--trans)" stroke-width="2"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke-linejoin="round"></path></svg> Sub-second, resident on GPU</span>
            <span class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="var(--load)" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a15 15 0 010 18M12 3a15 15 0 000 18"></path></svg> Auto-detects language</span>
          </div>
        </div>

        <!-- the living mark: 3D waveform-mynah -->
        <div class="hero-stage">
          <div class="stage-top">
            <kbd class="key" id="key">hold hotkey</kbd>
            <span class="state-chip" id="chip"><span class="dot" id="chipdot"></span><span id="chiptxt">Idle</span></span>
          </div>
          <div class="bird-stage">
            <canvas id="bird"></canvas>
            <canvas id="wave"></canvas>
            <img class="bird-fallback" src={`${base}brand/mynah-bird.png`} alt="Mynah" hidden />
          </div>
          <div class="editor">
            <div class="editor-bar"><i class="r"></i><i class="y"></i><i class="g"></i><span>~/project — mynah</span></div>
            <div class="editor-body">
              <div><span class="gutter">$</span><span class="prompt">claude</span></div>
              <div><span class="gutter">›</span><span class="typed" id="typed"></span><span class="cursor" id="cursor"></span></div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- ===================== HOW IT WORKS ===================== -->
    <section class="block" id="how">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">How it works</span>
          <h2 class="sec">One loop, fully on your machine</h2>
          <p class="sec-lede">
            A hotkey or wake word records mic audio, a resident whisper.cpp model transcribes it on
            the GPU, and the text is pasted at your cursor. The same runtime also handles language
            detection and voice-activity splitting — there's no second engine.
          </p>
        </div>
        <div class="pipe reveal">
          <div class="node" data-step="0">
            <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="7" width="18" height="10" rx="2"></rect><path d="M7 11h.01M11 11h.01M15 11h.01M8 14h8"></path></svg></div>
            <h4>Hotkey / wake word</h4><p>Hold the key, tap to toggle, or say "hey mynah".</p>
          </div>
          <div class="node" data-step="1">
            <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="3" width="6" height="11" rx="3"></rect><path d="M5 11a7 7 0 0014 0M12 18v3"></path></svg></div>
            <h4>Record mic</h4><p>16 kHz mono, only while you hold.</p>
          </div>
          <div class="node" data-step="2">
            <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"></rect><path d="M8 9v6M12 7v10M16 10v4"></path></svg></div>
            <h4>whisper.cpp on GPU</h4><p>large-v3, resident in VRAM.</p>
          </div>
          <div class="node" data-step="3">
            <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h10M4 12h16M4 18h12"></path><path d="M18 14l3 3-3 3"></path></svg></div>
            <h4>Paste at cursor</h4><p>Into any focused app, instantly.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURES ===================== -->
    <section class="block" id="features">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">Features</span>
          <h2 class="sec">Built to stay out of your way</h2>
        </div>
        <div class="grid reveal">
          <div class="card c-blue"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linejoin="round"></path><path d="M9 12l2 2 4-4"></path></svg></div>
            <h3>Private by design</h3><p>Everything runs on-device. No cloud calls, no account, no telemetry — your voice never leaves the machine.</p></div>
          <div class="card c-amber"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke-linejoin="round"></path></svg></div>
            <h3>Fast</h3><p>The model stays resident on the GPU, so a short utterance comes back in well under a second.</p></div>
          <div class="card c-purple"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a15 15 0 010 18M12 3a15 15 0 000 18"></path></svg></div>
            <h3>Accurate & multilingual</h3><p>Whisper large-v3 auto-detects the language and can split clips that mix several at once.</p></div>
          <div class="card c-red"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="3" width="6" height="11" rx="3"></rect><path d="M5 11a7 7 0 0014 0M12 18v3"></path></svg></div>
            <h3>Three ways to activate</h3><p>Hold-to-talk, tap-to-toggle, or hands-free wake word — whatever fits the moment.</p></div>
          <div class="card c-green"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="14" rx="2"></rect><path d="M8 21h8M12 18v3"></path></svg></div>
            <h3>Lives in the tray</h3><p>A color-coded tray icon shows state at a glance; everything is tunable in a Settings window.</p></div>
          <div class="card c-cyan"><div class="cic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.4H22l-6 4.5 2.3 7.1L12 16.6 5.7 21l2.3-7.1-6-4.5h7.6z"></path></svg></div>
            <h3>Free & open source</h3><p>MIT licensed, no paid tier. Runs from a small installer that downloads what it needs on first run.</p></div>
        </div>
      </div>
    </section>

    <!-- ===================== ACTIVATIONS ===================== -->
    <section class="block" id="activations">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">Three activations</span>
          <h2 class="sec">Start talking however suits the moment</h2>
        </div>
        <div class="acts reveal">
          <div class="act">
            <span class="pill-key">hold · F9 / ⌘⇧Space</span>
            <h3>Push-to-talk</h3>
            <p>Hold the key, speak, release. Walkie-talkie style — nothing records unless you're holding it.</p>
          </div>
          <div class="act">
            <span class="pill-key">tap · F10 / ⌃⇧Space</span>
            <h3>Toggle</h3>
            <p>Tap once to start, tap again to stop. Hands free for longer dictation, no key to hold down.</p>
          </div>
          <div class="act">
            <span class="pill-key">say · "hey mynah"</span>
            <h3>Wake word</h3>
            <p>Optional listening mode. A tiny CPU spotter waits for the phrase; the full model only runs on your dictation.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CUSTOMIZE ===================== -->
    <section class="block" id="customize">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">Make it yours</span>
          <h2 class="sec">One app, not one setting</h2>
          <p class="sec-lede">
            Mynah ships with sensible defaults, but nothing is hard-wired. Swap the GPU backend, pick
            a bigger or faster model, rebind the keys, change the wake phrase — all from the Settings
            window, the CLI, or a plain <code>config.toml</code>.
          </p>
        </div>
        <div class="custom-wrap reveal">
          <div class="opt-grid">
            <div class="opt">
              <h4><svg viewBox="0 0 24 24" fill="none" stroke="var(--idle)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"></rect><path d="M8 9v6M12 7v10M16 10v4"></path></svg> Backends</h4>
              <p>Auto-detected, override anytime.</p>
              <div class="tags"><span class="tag on">Vulkan</span><span class="tag on">Metal</span><span class="tag">CUDA</span><span class="tag">CPU</span></div>
            </div>
            <div class="opt">
              <h4><svg viewBox="0 0 24 24" fill="none" stroke="var(--trans)" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 3"></path></svg> Models</h4>
              <p>Trade speed, accuracy & VRAM.</p>
              <div class="tags"><span class="tag on">large-v3</span><span class="tag">turbo</span><span class="tag">medium</span><span class="tag">small</span></div>
            </div>
            <div class="opt">
              <h4><svg viewBox="0 0 24 24" fill="none" stroke="var(--load)" stroke-width="2"><rect x="3" y="6" width="18" height="12" rx="2"></rect><path d="M7 10h.01M11 10h.01M15 10h.01M8 14h8"></path></svg> Hotkeys</h4>
              <p>Rebind push-to-talk & toggle; stack combos.</p>
              <div class="tags"><span class="tag on">F9</span><span class="tag on">⌘⇧Space</span><span class="tag">F10</span><span class="tag">custom</span></div>
            </div>
            <div class="opt">
              <h4><svg viewBox="0 0 24 24" fill="none" stroke="#36d68a" stroke-width="2"><rect x="9" y="3" width="6" height="11" rx="3"></rect><path d="M5 11a7 7 0 0014 0M12 18v3"></path></svg> Wake phrase</h4>
              <p>Pick your own + tune sensitivity.</p>
              <div class="tags"><span class="tag on">"hey mynah"</span><span class="tag">custom</span></div>
            </div>
          </div>
          <div class="code">
            <div class="editor-bar"><i class="r"></i><i class="y"></i><i class="g"></i><span>config.toml</span></div>
<pre><span class="c"># everything below is optional — these are the defaults</span>
<span class="h">[model]</span>
<span class="k">name</span>    = <span class="s">"large-v3"</span>   <span class="c"># or large-v3-turbo / medium / small</span>

<span class="h">[hardware]</span>
<span class="k">backend</span> = <span class="s">"auto"</span>       <span class="c"># vulkan (PC) · metal (Mac) · cuda · cpu</span>

<span class="h">[hotkey]</span>            <span class="c"># macOS: cmd+shift+space / ctrl+shift+space</span>
<span class="k">push_to_talk</span> = <span class="s">"f9"</span>
<span class="k">toggle</span>       = <span class="s">"f10"</span>

<span class="h">[language]</span>
<span class="k">mode</span>         = <span class="s">"auto"</span>   <span class="c"># auto-detect per clip</span>
<span class="k">multilingual</span> = <span class="k">true</span>     <span class="c"># split mixed-language clips</span>

<span class="h">[wakeword]</span>
<span class="k">phrase</span>      = <span class="s">"hey mynah"</span>
<span class="k">sensitivity</span> = <span class="s">0.5</span></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== MULTILINGUAL ===================== -->
    <section class="block" id="multilingual">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">Multilingual, shown</span>
          <h2 class="sec">Mix languages in a single breath</h2>
          <p class="sec-lede">
            A cheap language check runs first; single-language clips take the fast path, and only
            clips that actually mix languages are split and transcribed — each part in its own
            language.
          </p>
        </div>
        <div class="lang-demo reveal">
          <div class="lang-clip">
            <span class="seg l-en"><span class="lang">English</span>let's ship the release,</span>
            <span class="seg l-ua"><span class="lang">Українська</span>але спершу прогони тести,</span>
            <span class="seg l-pl"><span class="lang">Polski</span>i sprawdź logi z produkcji</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== WHY ===================== -->
    <section class="block" id="why">
      <div class="wrap">
        <div class="reveal">
          <span class="kicker">Why it's built this way</span>
          <h2 class="sec">Decisions, with the numbers</h2>
          <p class="sec-lede">
            Mynah ships one engine across every platform and defaults to a GPU backend that needs no
            extra download. Both choices were benchmarked, not guessed.
          </p>
        </div>
        <div class="why-grid reveal">
          <div class="tbl-card">
            <div class="hd"><h3>One engine: whisper.cpp</h3><p>The alternative was measured at parity — so we kept the simpler one.</p></div>
            <table class="cmp">
              <tr><th>Engine</th><th>Backends</th><th>Extra GPU download</th></tr>
              <tr class="win-row"><td>whisper.cpp <span class="pill win">used</span></td><td>CPU · Vulkan · CUDA · Metal</td><td>none (Vulkan/CPU)</td></tr>
              <tr><td>faster-whisper</td><td>CPU · CUDA</td><td>~1.3 GB cuBLAS/cuDNN</td></tr>
            </table>
          </div>
          <div class="tbl-card">
            <div class="hd"><h3>GPU backend, auto-picked per OS</h3><p>Vulkan on PC, Metal on Apple Silicon — both ship inside the app, no download. RTX 2080 / M2 Pro, large-v3, warm short clip.</p></div>
            <table class="cmp">
              <tr><th>Backend</th><th>Works on</th><th>Ships how</th><th>Speed</th></tr>
              <tr class="win-row"><td>Vulkan <span class="pill def">PC default</span></td><td>NVIDIA/AMD/Intel</td><td>bundled (~74 MB)</td><td>sub-second</td></tr>
              <tr class="win-row"><td>Metal <span class="pill def">Mac default</span></td><td>Apple Silicon</td><td>bundled (~4 MB)</td><td>sub-second</td></tr>
              <tr><td>CPU</td><td>any machine</td><td>bundled (PC)</td><td>several s</td></tr>
              <tr><td>CUDA</td><td>NVIDIA only</td><td>download ~1.3 GB</td><td>≈ Vulkan</td></tr>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== GET STARTED ===================== -->
    <section class="cta-block">
      <div class="wrap reveal">
        <h2>Start dictating in two minutes</h2>
        <p>
          Grab the build for your OS. The GPU engine ships inside the app, so first run only
          downloads the model with a progress bar — then it just lives in your tray or menu bar.
        </p>
        <div class="cta-row">
          <a href={latestRelease} data-dl="windows" class="btn btn-primary btn-lg">Download for Windows</a>
          <a href={latestRelease} data-dl="macos" class="btn btn-primary btn-lg">Download for macOS</a>
          <a href={docs} class="btn btn-ghost btn-lg">Read the docs</a>
        </div>
        <div class="dl-meta">Windows: installer or portable .zip · macOS: Apple Silicon .dmg · GPU engine bundled · model fetched on first run</div>
      </div>
    </section>

    <footer class="site">
      <div class="wrap">
        <a class="brand" href={base}>
          <img src={`${base}brand/mynah-logo.png`} alt="Mynah" width="28" height="28" />
          <span><b>My</b><span class="accent">nah</span></span>
        </a>
        <span class="lic">MIT licensed · local-only · made for people who'd rather talk than type.</span>
        <div class="links">
          <a href={docs}>Docs</a><a href={gh}>GitHub</a><a href={releases}>Releases</a><a href={`${gh}/blob/master/LICENSE`}>License</a>
        </div>
      </div>
    </footer>

    <script>
      // Download buttons → newest *versioned* asset. We ask the GitHub releases API for the
      // latest release, match the Windows installer / macOS zip by filename, and navigate to it
      // (so the saved file keeps its version, e.g. Mynah-Setup-0.4.0.exe). The button's href is
      // the /releases/latest page, so if the API is rate-limited / offline the click still works.
      (() => {
        const API = 'https://api.github.com/repos/RSRaven/mynah/releases/latest';
        const pick = (assets, os) => {
          const find = (re) => assets.find((a) => re.test(a.name));
          if (os === 'windows') return find(/^Mynah-Setup-.*\.exe$/) || find(/\.exe$/);
          if (os === 'macos') return find(/macos-arm64\.dmg$/) || find(/macos-arm64\.zip$/) || find(/\.dmg$/);
          return undefined;
        };
        let cache = null;
        const load = () => {
          if (cache) return cache;
          cache = fetch(API, { headers: { Accept: 'application/vnd.github+json' } })
            .then((r) => (r.ok ? r.json() : null))
            .catch(() => null);
          return cache;
        };
        const btns = Array.from(document.querySelectorAll('a[data-dl]'));
        // Warm the API call on first hover so the click feels instant.
        btns.forEach((b) => b.addEventListener('pointerenter', load, { once: true }));
        btns.forEach((b) =>
          b.addEventListener('click', async (e) => {
            const os = b.getAttribute('data-dl');
            const rel = await load();
            const asset = rel && rel.assets ? pick(rel.assets, os) : null;
            if (asset && asset.browser_download_url) {
              e.preventDefault();
              window.location.href = asset.browser_download_url;
            }
            // else: let the default href (the /releases/latest page) handle it.
          })
        );
      })();

      // Three.js is heavy, so load the hero lazily — only when it scrolls into view.
      const run = () => {
        const boot = () => import('../scripts/bird-hero').then((m) => m.initBirdHero());
        if ('requestIdleCallback' in window) {
          (window as any).requestIdleCallback(boot);
        } else {
          setTimeout(boot, 200);
        }
      };
      // only spin up WebGL when the hero is actually on screen
      const stage = document.querySelector('.bird-stage');
      if (stage && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries, obs) => {
          if (entries.some((e) => e.isIntersecting)) {
            obs.disconnect();
            run();
          }
        });
        io.observe(stage);
      } else {
        run();
      }

      // scroll-reveal + pipeline light-up (mirrors the original 2D hero)
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const io2 = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              e.target.classList.add('in');
              const nodes = e.target.querySelectorAll('.node');
              nodes.forEach((n, i) => setTimeout(() => n.classList.add('lit'), 250 + i * 320));
              io2.unobserve(e.target);
            });
          },
          { threshold: 0.18 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io2.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
        document.querySelectorAll('.node').forEach((n) => n.classList.add('lit'));
      }
    </script>
  </body>
</html>
